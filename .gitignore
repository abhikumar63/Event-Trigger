# --- Industry Standard .gitignore for Go + Java (Maven) + Docker Project ---

# OS Specific
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# IDEs and Editors
.idea/
.vscode/
*.swp
*.swo
*~
*.bak
*.tmp

# Go
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/
# Test binaries
*.test
# Output of the go coverage tool
*.out

# Java & Maven
target/
*.class
*.log
*.ctxt
# Mobile Tools for Java (J2ME)
.mtj.tmp/
# Package Files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
# dependency-reduced-pom.xml
dependency-reduced-pom.xml

# Docker
.docker/
docker-compose.override.yml

# Environment Variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Temporary Files and Logs
logs/
*.log
tmp/
temp/
